{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../../logs/current.json",
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 104857600
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "capacitor://localhost"
    ]
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=litigapp;Username=litigapp;Password=litigapp_dev"
  },
  "RamaJudicial": {
    "BaseUrl": "https://consultaprocesos.ramajudicial.gov.co:448",
    "TimeoutSeconds": 30,
    "DelayBetweenRequestsMs": 2500,
    "DelayJitterMs": 500,
    "MaxConcurrentRequests": 1,
    "Sweep": {
      "OverviewIntervalMinutes": 15,
      "BatchSize": 50,
      "MinimumHoursBetweenSyncsPerProcess": 22
    },
    "Throttle": {
      "OverviewIntervalSecondsMin": 2,
      "OverviewIntervalSecondsMax": 3,
      "ActionsIntervalSecondsMin": 2,
      "ActionsIntervalSecondsMax": 3
    },
    "Waf": {
      "CooldownMinutesOnBlock": 20,
      "ConsecutiveSuccessesToSpeedUp": 100,
      "ConsecutiveBlocksToSlowDown": 1,
      "EmergencyMaxThrottleSeconds": 10
    }
  },
  "Jwt": {
    "Secret": "dev-placeholder-override-via-Jwt__Secret-env-var-in-prod-min32chars",
    "Issuer": "LitigApp",
    "Audience": "LitigApp",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  }
}
