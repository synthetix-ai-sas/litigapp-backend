{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "capacitor://localhost",
      "https://litigapp-web.vercel.app"
    ]
  },
  "RamaJudicial": {
    "BaseUrl": "https://consultaprocesos.ramajudicial.gov.co:448",
    "TimeoutSeconds": 30,
    "DelayBetweenRequestsMs": 500,
    "DelayJitterMs": 500,
    "MaxConcurrentRequests": 1,
    "Sweep": {
      "OverviewIntervalMinutes": 15,
      "BatchSize": 50,
      "MinimumHoursBetweenSyncsPerProcess": 22
    },
    "Throttle": {
      "OverviewIntervalSecondsMin": 2,
      "OverviewIntervalSecondsMax": 3,
      "ActionsIntervalSecondsMin": 2,
      "ActionsIntervalSecondsMax": 3
    },
    "Waf": {
      "CooldownMinutesOnBlock": 20,
      "ConsecutiveSuccessesToSpeedUp": 100,
      "ConsecutiveBlocksToSlowDown": 1,
      "EmergencyMaxThrottleSeconds": 10
    }
  },
  "Import": {
    "MaxFileSizeBytes": 2097152,
    "MaxRows": 5000,
    "PreviewCacheTtlMinutes": 10
  },
  "Database": {
    "MaxPoolSize": 6
  },
  "Resend": {
    "FromAddress": "contac@notifications.synthetixaisas.com",
    "FromName": "LitigApp"
  },
  "Notifications": {
    "DigestMaxRows": 5,
    "AppBaseUrl": "https://litigapp-web.vercel.app/login"
  },
  "Hangfire": {
    "WorkerCount": 3
  },
  "Jwt": {
    "Issuer": "LitigApp",
    "Audience": "LitigApp",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Legal": {
    "TermsVersion": "v1.0",
    "PrivacyVersion": "v1.0",
    "DataProtectionEmail": "protecciondedatos@tododeia.com"
  }
}
