# litigapp-worker — Railway service running Hangfire jobs only, no HTTP surface.
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY . .
RUN dotnet publish src/LitigApp.Api/LitigApp.Api.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
# Install system dependencies required by the PostgreSQL driver (Npgsql) — same
# native libs needed in Dockerfile.api, since this image runs the same EF Core /
# Hangfire.PostgreSql code against the same base runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgssapi-krb5-2 \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build /app .
ENV ASPNETCORE_URLS=
ENV ASPNETCORE_HTTP_PORTS=
ENV LITIGAPP_ROLE=worker
ENTRYPOINT ["dotnet", "LitigApp.Api.dll"]
