<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- Repo-scoped feed config so restore is deterministic regardless of a dev's global
       NuGet.Config. Required by Central Package Management: with >1 source, every source
       must be covered by package source mapping (NU1507). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github-synthetix-ai" value="https://nuget.pkg.github.com/synthetix-ai-sas/index.json" />
  </packageSources>

  <!-- Every current dependency is public → nuget.org. The org's private GitHub feed is
       reserved for internal packages published under the Synthetix.* prefix; nothing in
       this repo uses it today, so restore never contacts it (no auth needed). -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-synthetix-ai">
      <package pattern="Synthetix.*" />
    </packageSource>
  </packageSourceMapping>

</configuration>
